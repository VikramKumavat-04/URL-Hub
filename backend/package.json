{
  "name": "urlhub-backend",
  "version": "1.0.0",
  "description": "URLHub — production URL shortener backend",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "render-build": "npm install && cd ../frontend && npm install && npm run build && cp -r dist ../backend/public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
